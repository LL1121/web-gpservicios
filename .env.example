# ─────────────────────────────────────────────────────────────────────────────
# Puerto del host que mapea al 3000 interno del contenedor.
# Default: 3004 (el 3000 ya está ocupado en el servidor de Lyntrix).
# ─────────────────────────────────────────────────────────────────────────────
FRONT_PORT=3004

# ─────────────────────────────────────────────────────────────────────────────
# SMTP — formulario de contacto.
# Si dejás estas vars vacías el form devuelve un error pidiéndole al usuario
# que escriba directamente al correo institucional.
#
# Ejemplo Gmail (con clave de aplicación):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=usuario@gmail.com
#   SMTP_PASS=xxxx-xxxx-xxxx-xxxx
#
# Ejemplo Office 365 / Outlook:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#
# Ejemplo SMTP corporativo del dominio (gpservicios.com.ar):
#   SMTP_HOST=mail.gpservicios.com.ar
#   SMTP_PORT=465
#   SMTP_SECURE=true
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Casilla destino donde llegan los mensajes del form.
CONTACT_TO_EMAIL=comercial@gpservicios.com.ar

# Casilla "From:" del email enviado por el form.
# Suele coincidir con SMTP_USER. Si lo dejás vacío usa CONTACT_TO_EMAIL.
CONTACT_FROM_EMAIL=
